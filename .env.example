# UL OS Telegram Bot - env config
# Skopiuj do .env i uzupelnij. NIGDY nie commituj .env do repo (jest w .gitignore).

# === Telegram (KRYTYCZNE) ===
TELEGRAM_BOT_TOKEN=8728521569:AAH-...your-token-here

# Whitelist user_id (oddzielone przecinkami)
# Zdobadz user_id wysylajac /start do bota i sprawdzajac logs/audit.jsonl
ADMIN_CHAT_IDS=123456789,987654321

# === Mode ===
USE_WEBHOOK=false

# Tylko jezeli USE_WEBHOOK=true:
WEBHOOK_URL=https://bot.osadathehive.pl/telegram/webhook
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_PORT=8080
WEBHOOK_SECRET=random-string-here-uzyj-openssl-rand

# === Directus ===
DIRECTUS_URL=https://cms.osadathehive.pl
DIRECTUS_TOKEN=...

# === MCP Server (UL OS Knowledge bridge) ===
MCP_BASE_URL=https://mcp.bidbee.pl
MCP_BEARER_TOKEN=...

# === Worker UL OS (po deploymencie w Coolify, project ul-os) ===
WORKER_URL=http://ul-os-worker:3000
WORKER_SECRET=...

# === Hetzner Object Storage (per ADR-001 z 2026-05-09) ===
# Wczesniej planowany B2 - ADR-001 przeszedl na HOS jako single-vendor
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_BUCKET=ul-os-storage
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_REGION=nbg1

# === Tenant (per ADR-008 multi-tenant od dnia 1) ===
TENANT_ID=hivelive_ecosystem

# === Observability ===
# Sentry (error tracking + performance) - patrz _RUNBOOK_sentry-setup.md
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Logging format: 'text' (dev) / 'json' (production - parsowalne dla Loki)
LOG_FORMAT=text
